# VisionGuard — backend / pipeline environment
# Copy to `.env` in the project root and fill in real values. Never commit `.env`.

# -----------------------------------------------------------------------------
# PostgreSQL (SQLAlchemy — see src/database/session.py)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/visionguard

# -----------------------------------------------------------------------------
# Cerebras Cloud LLM (src/llm/llm_service.py — POST /runs/{id}/llm)
# Get an API key from https://cloud.cerebras.ai
# -----------------------------------------------------------------------------
CEREBRAS_API_KEY=
# Optional; default in code is llama3.1-8b
CEREBRAS_MODEL=llama3.1-8b

# -----------------------------------------------------------------------------
# Clerk — JWT verification for FastAPI (src/api/auth.py)
# Dashboard: https://dashboard.clerk.com → API Keys
# -----------------------------------------------------------------------------
# Publishable key (same value as frontend VITE_CLERK_PUBLISHABLE_KEY, without VITE_ prefix)
CLERK_PUBLISHABLE_KEY=pk_test_c3RpcnJpbmctbWFsYW11dGUtNDMuY2xlcmsuYWNjb3VudHMuZGV2JA
# Secret key — server only; never expose to the browser
CLERK_SECRET_KEY=sk_test_tZlv3MxwZ2q7os9oPyVPuIuhfUOXyuTOPAu2sakYzx
# JWT issuer / Frontend API URL (must match Clerk Dashboard → API Keys → Frontend API)
# Example: https://your-subdomain.clerk.accounts.dev
CLERK_ISSUER=https://stirring-malamute-43.clerk.accounts.dev


