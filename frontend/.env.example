# VisionGuard — Vite frontend (copy to `frontend/.env`)
# Variables prefixed with VITE_ are embedded in the client bundle at build time.
# On Vercel, set the same names under Project → Settings → Environment Variables (Production, then redeploy).

# FastAPI base URL (see frontend/src/lib/api.js). Default if unset: http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# Clerk publishable key only — safe to expose in the browser
# Dashboard: https://dashboard.clerk.com → API Keys → Publishable key
# Must match the backend CLERK_PUBLISHABLE_KEY (same string)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_c3RpcnJpbmctbWFsYW11dGUtNDMuY2xlcmsuYWNjb3VudHMuZGV2JA


